page { background: #0d1420; color: #dbe4f3; font-size: 14px; }

.page { display: flex; flex-direction: column; min-height: 100vh; padding: 0 16px 100px; box-sizing: border-box; }

/* header */
.header { padding: 20px 0 12px; }
.logo-wrap { display: flex; align-items: center; gap: 8px; }
.logo-icon { width: 32px; height: 32px; background: #7c89ff; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 16px; color: #fff; }
.logo-text { font-size: 17px; font-weight: 700; color: #fff; }
.logo-badge { font-size: 10px; color: #aab7cc; background: #1a2537; padding: 2px 8px; border-radius: 20px; font-weight: 600; }

/* section */
.section { margin-bottom: 16px; }

/* upload */
.upload-box { position: relative; min-height: 180px; border-radius: 16px; border: 1.5px dashed #34435c; background: #182234; display: flex; align-items: center; justify-content: center; overflow: hidden; }
.upload-box.has-image { border-style: solid; border-color: #566785; }
.upload-placeholder { display: flex; flex-direction: column; align-items: center; gap: 8px; }
.upload-icon { font-size: 36px; }
.upload-title { font-size: 15px; font-weight: 600; color: #fff; }
.upload-hint { font-size: 12px; color: #8fa0bb; }
.preview-img { width: 100%; height: 220px; }
.preview-overlay { position: absolute; bottom: 0; left: 0; right: 0; background: linear-gradient(transparent, rgba(0,0,0,0.7)); padding: 16px; display: flex; }
.replace-btn { background: #fff; color: #111; font-size: 13px; font-weight: 600; padding: 6px 16px; border-radius: 20px; }
.clear-btn { position: absolute; top: 10px; right: 10px; width: 28px; height: 28px; border-radius: 50%; background: rgba(0,0,0,0.6); color: #fff; display: flex; align-items: center; justify-content: center; font-size: 13px; }

/* fields */
.field { display: flex; align-items: center; justify-content: space-between; background: #121d2d; border: 1px solid #263348; border-radius: 14px; padding: 12px 16px; margin-bottom: 10px; }
.field-label { font-size: 13px; color: #8fa0bb; font-weight: 500; }
.picker-btn { font-size: 14px; font-weight: 600; color: #fff; }
.picker-arrow { color: #7c89ff; }
.seed-row { display: flex; align-items: center; gap: 10px; }
.seed-input { width: 100px; text-align: right; font-size: 14px; color: #fff; font-weight: 600; background: transparent; }
.dice-btn { font-size: 20px; }

/* error */
.error-box { background: rgba(220,38,38,0.15); border: 1px solid rgba(220,38,38,0.3); border-radius: 12px; padding: 12px 14px; margin-bottom: 12px; display: flex; align-items: flex-start; gap: 8px; }
.error-text { flex: 1; font-size: 13px; color: #fca5a5; line-height: 1.5; }
.error-close { color: #fca5a5; font-size: 14px; }

/* progress */
.progress-box { display: flex; align-items: center; gap: 10px; background: #121d2d; border: 1px solid #263348; border-radius: 12px; padding: 14px 16px; margin-bottom: 12px; }
.spinner { width: 18px; height: 18px; border: 2px solid rgba(124,137,255,0.3); border-top-color: #7c89ff; border-radius: 50%; animation: spin 0.8s linear infinite; flex-shrink: 0; }
@keyframes spin { to { transform: rotate(360deg); } }
.progress-text { font-size: 13px; color: #aab7cc; }

/* footer */
.footer { position: fixed; bottom: 60px; left: 16px; right: 16px; }
.generate-btn { background: #7c89ff; color: #fff; font-size: 16px; font-weight: 700; text-align: center; padding: 16px; border-radius: 20px; box-shadow: 0 12px 30px rgba(124,137,255,0.3); }
.generate-btn.disabled { background: #1a2537; color: #62718a; box-shadow: none; }
