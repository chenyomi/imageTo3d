<view class="page">
  <view class="page-glow page-glow-left"></view>
  <view class="page-glow page-glow-right"></view>

  <!-- 顶部标题 -->
  <view class="header">
    <view class="logo-wrap">
      <view class="logo-icon">
        <image class="logo-icon-image" src="/assets/logo-cube.svg" mode="aspectFit" />
      </view>
      <view class="logo-copy">
        <view class="logo-line">
          <text class="logo-text">ImageTo3D</text>
          <text class="logo-badge">PIXAL3D</text>
        </view>
        <text class="logo-subtext">从单张图片快速生成可下载的 3D 模型</text>
      </view>
    </view>
  </view>

  <!-- 图片上传区 -->
  <view class="section">
    <view class="upload-box {{imageUri ? 'has-image' : ''}}" bindtap="chooseImage">
      <view class="upload-mesh"></view>
      <block wx:if="{{imageUri}}">
        <image class="preview-img" src="{{imageUri}}" mode="aspectFill" catchtap="previewSelectedImage" />
        <view class="preview-overlay">
          <view class="preview-meta">
            <text class="preview-eyebrow">Source Image</text>
            <text class="preview-title">已选择图片，可点按查看完整预览</text>
          </view>
          <view class="replace-btn" catchtap="chooseImage">换图</view>
        </view>
        <view class="clear-btn" catchtap="clearImage">✕</view>
      </block>
      <block wx:else>
        <view class="upload-placeholder">
          <view class="upload-hero">
            <view class="upload-hero-ring"></view>
            <view class="upload-hero-tile tile-back"></view>
            <view class="upload-hero-tile tile-front"></view>
            <view class="upload-hero-plus"></view>
          </view>
          <text class="upload-title">选择一张主体清晰的图片</text>
          <text class="upload-hint">支持 JPG、PNG、WEBP，自动完成预处理与 3D 重建</text>
          <view class="upload-chips">
            <text class="upload-chip">Portrait</text>
            <text class="upload-chip">Product</text>
            <text class="upload-chip">Vehicle</text>
          </view>
        </view>
      </block>
    </view>
  </view>

  <!-- 参数设置 -->
  <view class="section">
    <view class="field">
      <view class="field-copy">
        <text class="field-label">分辨率</text>
        <text class="field-sublabel">输出质量与生成速度</text>
      </view>
      <picker mode="selector" range="{{resolutionOptions}}" value="{{resolutionIdx}}" bindchange="onResolutionChange">
        <view class="picker-btn">{{resolutionOptions[resolutionIdx]}} <text class="picker-arrow">▾</text></view>
      </picker>
    </view>
    <view class="field">
      <view class="field-copy">
        <text class="field-label">随机种子</text>
        <text class="field-sublabel">固定参数可复现结果</text>
      </view>
      <view class="seed-row">
        <input class="seed-input" type="number" value="{{seed}}" bindinput="onSeedInput" placeholder="-1 随机" />
        <view class="dice-btn" bindtap="randomSeed">随机</view>
      </view>
    </view>
  </view>

  <!-- 错误提示 -->
  <view class="error-box" wx:if="{{error}}">
    <text class="error-text">{{error}}</text>
    <view class="error-close" bindtap="clearError">✕</view>
  </view>

  <!-- 进度提示 -->
  <view class="progress-box" wx:if="{{loading}}">
    <view class="spinner"></view>
    <view class="progress-copy">
      <text class="progress-title">实时进度</text>
      <text class="progress-text">{{progressText}}</text>
    </view>
  </view>

  <!-- 生成按钮 -->
  <view class="footer">
    <view
      class="generate-btn {{!imageUri || loading ? 'disabled' : ''}}"
      bindtap="handleGenerate"
    >
      <view class="generate-btn-inner">
        <view class="generate-spark"></view>
        <text wx:if="{{loading}}">生成中...</text>
        <text wx:else>开始生成</text>
      </view>
    </view>
  </view>

</view>
