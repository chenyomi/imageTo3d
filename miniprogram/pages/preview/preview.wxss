page { background: #0d1420; }

.page { position: relative; min-height: 100vh; overflow: hidden; background:
	radial-gradient(circle at 12% 0%, rgba(124,137,255,0.22), transparent 28%),
	radial-gradient(circle at 88% 14%, rgba(79, 209, 255, 0.13), transparent 24%),
	linear-gradient(180deg, #0c1522 0%, #09111b 100%); }
.page-aurora { position: absolute; border-radius: 999px; filter: blur(70px); opacity: 0.22; pointer-events: none; }
.page-aurora-left { width: 170px; height: 170px; background: #7c89ff; top: -20px; left: -100px; }
.page-aurora-right { width: 170px; height: 170px; background: #56d6ff; top: 220px; right: -110px; }

.viewer-shell { position: relative; min-height: 100vh; overflow: hidden; }

.model-viewer { width: 100%; height: 100vh; }
.viewer-grid { position: absolute; inset: 0; background-image: linear-gradient(rgba(160,178,211,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(160,178,211,0.04) 1px, transparent 1px); background-size: 26px 26px; pointer-events: none; z-index: 1; }

.viewer-topbar { position: absolute; top: 18px; left: 16px; right: 16px; display: flex; align-items: flex-start; justify-content: space-between; gap: 10px; z-index: 3; }

.viewer-back,
.viewer-title-wrap,
.viewer-download,
.viewer-bottom-panel,
.viewer-loading { backdrop-filter: blur(18px); }

.viewer-back { min-width: 68px; padding: 12px 14px; border-radius: 999px; background: rgba(11, 18, 29, 0.72); border: 1px solid rgba(129, 153, 184, 0.18); color: #eef4fe; font-size: 13px; font-weight: 700; text-align: center; }

.viewer-title-wrap { flex: 1; display: flex; flex-direction: column; gap: 6px; padding: 12px 14px; border-radius: 18px; background: rgba(10, 18, 30, 0.72); border: 1px solid rgba(129, 153, 184, 0.18); }

.viewer-eyebrow { font-size: 11px; font-weight: 700; letter-spacing: 1px; color: #7bdff6; }

.viewer-title { font-size: 17px; font-weight: 700; color: #fff; line-height: 1.35; }

.viewer-download { min-width: 72px; padding: 12px 16px; border-radius: 999px; background: linear-gradient(135deg, #82d8ff, #7c89ff); color: #09111c; font-size: 13px; font-weight: 800; text-align: center; box-shadow: 0 12px 30px rgba(124,137,255,0.28); }

.viewer-bottom-panel { position: absolute; left: 16px; right: 16px; bottom: 98px; display: flex; align-items: center; justify-content: space-between; gap: 12px; padding: 14px 16px; border-radius: 22px; background: rgba(10, 18, 30, 0.74); border: 1px solid rgba(129, 153, 184, 0.18); z-index: 3; }
.viewer-meta-block { display: flex; flex-direction: column; gap: 4px; min-width: 60px; }
.viewer-meta-block.center { align-items: center; justify-content: center; }
.viewer-meta-block.align-right { align-items: flex-end; }
.viewer-meta-label { font-size: 11px; color: #7d8da8; }
.viewer-meta-value { font-size: 13px; font-weight: 700; color: #edf4ff; }
.viewer-orb { width: 32px; height: 32px; opacity: 0.92; }

.viewer-loading { position: absolute; left: 50%; bottom: 32px; transform: translateX(-50%); display: flex; align-items: center; gap: 10px; padding: 12px 16px; border-radius: 999px; background: rgba(10, 18, 30, 0.78); border: 1px solid rgba(129, 153, 184, 0.18); z-index: 3; }

.viewer-spinner { width: 16px; height: 16px; border: 2px solid rgba(124,137,255,0.24); border-top-color: #7c89ff; border-radius: 50%; animation: spin 0.8s linear infinite; }

.viewer-loading-text { font-size: 12px; color: #d5e0f2; }
@keyframes spin { to { transform: rotate(360deg); } }

.fallback { min-height: 100vh; padding: 24px 16px; display: flex; align-items: center; justify-content: center; box-sizing: border-box; }

.fallback-card { width: 100%; background: linear-gradient(180deg, rgba(16, 27, 42, 0.98) 0%, rgba(10, 18, 30, 0.98) 100%); border: 1px solid rgba(94, 114, 145, 0.28); border-radius: 30px; padding: 22px 18px 18px; box-shadow: 0 24px 80px rgba(0, 0, 0, 0.34); }

.fallback-badge { display: inline-flex; align-items: center; justify-content: center; padding: 7px 12px; border-radius: 999px; background: rgba(123, 223, 246, 0.12); border: 1px solid rgba(123, 223, 246, 0.16); color: #8ce5ff; font-size: 11px; font-weight: 800; letter-spacing: 0.8px; text-transform: uppercase; }

.fallback-header { margin-top: 16px; display: flex; align-items: center; gap: 14px; }

.fallback-icon-wrap { position: relative; width: 64px; height: 64px; flex-shrink: 0; }

.fallback-icon-ring { position: absolute; inset: 0; border-radius: 22px; background: linear-gradient(135deg, rgba(130, 216, 255, 0.22), rgba(124, 137, 255, 0.16)); border: 1px solid rgba(130, 216, 255, 0.16); box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.06); }

.fallback-icon-core { position: absolute; inset: 14px; border-radius: 16px; background: #101b2b; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 5px; }

.fallback-logo { width: 22px; height: 22px; display: block; }

.fallback-headline { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 6px; }

.fallback-title { display: block; font-size: 21px; line-height: 1.25; font-weight: 800; color: #f4f8ff; }

.fallback-subtitle { display: block; font-size: 12px; line-height: 1.7; color: #8ea1bf; }

.fallback-diagnosis { margin-top: 18px; padding: 14px; border-radius: 22px; background: rgba(7, 14, 24, 0.54); border: 1px solid rgba(94, 114, 145, 0.18); display: flex; flex-direction: column; gap: 12px; }

.fallback-row { display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; }

.fallback-row.detail { flex-direction: column; }

.fallback-row-label { font-size: 11px; font-weight: 700; letter-spacing: 0.6px; text-transform: uppercase; color: #6f829e; }

.fallback-row-value { font-size: 13px; font-weight: 700; color: #edf4ff; }

.fallback-row-value.danger { color: #ff9cab; }

.fallback-text { display: block; font-size: 13px; line-height: 1.8; color: #b8c8df; }

.fallback-actions { margin-top: 18px; display: flex; gap: 10px; }

.fallback-btn { flex: 1; display: inline-flex; align-items: center; justify-content: center; min-width: 0; padding: 13px 16px; border-radius: 18px; background: linear-gradient(135deg, #82d8ff, #7c89ff); color: #07111d; font-size: 14px; font-weight: 800; box-shadow: 0 14px 28px rgba(124,137,255,0.18); }

.fallback-btn.secondary { background: rgba(24, 34, 52, 0.9); color: #d6e0ef; border: 1px solid #2a3950; box-shadow: none; }