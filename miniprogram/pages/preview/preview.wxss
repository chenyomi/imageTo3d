page {
	background: #09111b;
}

.preview-empty {
	min-height: 100vh;
	padding: 32px 20px;
	box-sizing: border-box;
	display: flex;
	flex-direction: column;
	align-items: center;
	justify-content: center;
	text-align: center;
	background:
		radial-gradient(circle at 14% 0%, rgba(124, 137, 255, 0.22), transparent 28%),
		radial-gradient(circle at 88% 18%, rgba(86, 214, 255, 0.16), transparent 24%),
		linear-gradient(180deg, #08111c 0%, #0b1624 100%);
}

.preview-empty-logo {
	width: 72px;
	height: 72px;
	margin-bottom: 18px;
}

.preview-empty-title {
	font-size: 22px;
	line-height: 1.3;
	font-weight: 800;
	color: #f4f8ff;
}

.preview-empty-text {
	margin-top: 10px;
	max-width: 300px;
	font-size: 13px;
	line-height: 1.8;
	color: #9bb0ca;
}

.preview-empty-btn {
	margin-top: 20px;
	min-width: 126px;
	padding: 12px 18px;
	border-radius: 999px;
	background: linear-gradient(135deg, #82d8ff, #7c89ff);
	color: #07111d;
	font-size: 14px;
	font-weight: 800;
	box-shadow: 0 14px 30px rgba(124, 137, 255, 0.2);
}