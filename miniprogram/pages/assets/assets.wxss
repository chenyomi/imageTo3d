page { background: #0d1420; color: #dbe4f3; }

.page { position: relative; min-height: 100vh; padding: 20px 16px 44px; box-sizing: border-box; overflow: hidden; background:
	radial-gradient(circle at 0% 0%, rgba(124,137,255,0.18), transparent 28%),
	radial-gradient(circle at 100% 18%, rgba(79, 209, 255, 0.12), transparent 24%),
	linear-gradient(180deg, #0f1724 0%, #0b1320 100%); }
.page-glow { position: absolute; border-radius: 999px; filter: blur(60px); opacity: 0.24; pointer-events: none; }
.page-glow-left { width: 160px; height: 160px; background: #7c89ff; top: 10px; left: -100px; }
.page-glow-right { width: 160px; height: 160px; background: #56d6ff; top: 150px; right: -110px; }

.header { position: relative; z-index: 1; margin-bottom: 18px; display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; }
.header-copy { display: flex; flex-direction: column; gap: 6px; }
.title { font-size: 22px; font-weight: 800; color: #fff; }
.subtitle { font-size: 12px; line-height: 1.7; color: #7f8ea8; max-width: 220px; }
.header-badge { padding: 8px 12px; border-radius: 999px; background: rgba(24, 35, 54, 0.84); border: 1px solid rgba(94, 114, 145, 0.22); color: #dce8ff; font-size: 12px; font-weight: 700; }

.task-card { position: relative; z-index: 1; display: flex; align-items: center; gap: 12px; background: linear-gradient(180deg, rgba(19, 30, 47, 0.96), rgba(15, 24, 38, 0.98)); border: 1px solid rgba(77, 95, 123, 0.34); border-radius: 18px; padding: 14px; margin-bottom: 14px; box-shadow: inset 0 1px 0 rgba(255,255,255,0.03); }
.task-card.error { border-color: rgba(220,38,38,0.28); background: rgba(81, 26, 35, 0.48); }
.task-card-icon { width: 38px; height: 38px; border-radius: 14px; background: #182234; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.task-card-icon.live { background: linear-gradient(135deg, rgba(124,137,255,0.22), rgba(79,209,255,0.22)); }
.task-card-icon.error-mark { color: #ffb4c0; font-size: 18px; font-weight: 800; }
.task-card-content { display: flex; flex-direction: column; gap: 3px; min-width: 0; flex: 1; }
.task-card-title { font-size: 14px; font-weight: 700; color: #edf4ff; }
.task-card-text { font-size: 12px; line-height: 1.6; color: #8fa0bb; }
.task-card-tag { padding: 7px 9px; border-radius: 999px; background: rgba(93, 207, 255, 0.12); border: 1px solid rgba(93, 207, 255, 0.2); color: #8de5ff; font-size: 10px; font-weight: 800; letter-spacing: 0.5px; }
.spinner { width: 18px; height: 18px; border: 2px solid rgba(124,137,255,0.3); border-top-color: #7c89ff; border-radius: 50%; animation: spin 0.8s linear infinite; }
@keyframes spin { to { transform: rotate(360deg); } }

.empty { position: relative; z-index: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 84px 12px 40px; gap: 14px; text-align: center; }
.empty-logo { width: 72px; height: 72px; opacity: 0.96; display: block; }
.empty-title { font-size: 18px; font-weight: 800; color: #eef4fe; }
.empty-hint { max-width: 260px; font-size: 13px; line-height: 1.8; color: #7f8ea8; }

.mark-cube-image { width: 22px; height: 22px; display: block; }
.mark-cube-image.small { width: 16px; height: 16px; }

.list { position: relative; z-index: 1; display: flex; flex-direction: column; gap: 12px; }
.asset-item { display: flex; align-items: center; gap: 12px; background: linear-gradient(180deg, rgba(19, 30, 47, 0.96), rgba(15, 24, 38, 0.98)); border: 1px solid rgba(77, 95, 123, 0.34); border-radius: 20px; padding: 12px; box-shadow: inset 0 1px 0 rgba(255,255,255,0.03); }
.asset-cover { width: 64px; height: 64px; border-radius: 16px; overflow: hidden; background: #182234; flex-shrink: 0; border: 1px solid rgba(255,255,255,0.04); }
.asset-cover-image { width: 100%; height: 100%; }
.asset-cover-fallback { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: linear-gradient(145deg, rgba(124,137,255,0.26), rgba(93, 207, 255, 0.12)); }
.asset-info { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 4px; }
.asset-name { display: block; font-size: 15px; font-weight: 700; color: #edf4ff; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.asset-time { display: block; font-size: 11px; color: #71809a; }
.asset-pills { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 2px; }
.asset-pill { padding: 4px 8px; border-radius: 999px; background: rgba(26, 38, 58, 0.9); border: 1px solid rgba(94, 114, 145, 0.2); color: #adc0db; font-size: 10px; font-weight: 700; }
.asset-actions { display: flex; flex-direction: column; gap: 8px; flex-shrink: 0; }
.action-btn { min-width: 60px; text-align: center; font-size: 12px; font-weight: 700; color: #dfe9ff; background: rgba(24, 35, 54, 0.88); border: 1px solid rgba(96, 116, 147, 0.22); padding: 7px 12px; border-radius: 999px; }
.action-btn.danger { color: #ffb6c3; background: rgba(255, 107, 129, 0.12); border-color: rgba(255, 107, 129, 0.16); }
