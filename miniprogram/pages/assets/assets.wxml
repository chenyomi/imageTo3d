<view class="page">

  <view class="header">
    <text class="title">历史模型</text>
    <text class="subtitle">{{assets.length}} 个</text>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{assets.length === 0}}">
    <text class="empty-icon">◈</text>
    <text class="empty-title">暂无模型</text>
    <text class="empty-hint">生成后会显示在这里</text>
  </view>

  <!-- 列表 -->
  <view class="list" wx:else>
    <view class="asset-item" wx:for="{{assets}}" wx:key="id">
      <view class="asset-icon">◈</view>
      <view class="asset-info">
        <text class="asset-name">{{item.name}}</text>
        <text class="asset-time">{{item.createdAt}}</text>
      </view>
      <view class="asset-actions">
        <view class="action-btn" catchtap="downloadGlb" data-url="{{item.glbUrl}}" data-name="{{item.name}}">下载</view>
      </view>
    </view>
  </view>

</view>
