<view class="page">
  <view class="page-glow page-glow-left"></view>
  <view class="page-glow page-glow-right"></view>

  <view class="header">
    <view class="header-copy">
      <text class="title">模型库</text>
      <text class="subtitle">查看已生成结果、继续预览或下载本地文件</text>
    </view>
    <view class="header-badge">{{assets.length}} 个</view>
  </view>

  <view class="task-card" wx:if="{{generationTask && generationTask.status === 'running'}}">
    <view class="task-card-icon live">
      <view class="spinner"></view>
    </view>
    <view class="task-card-content">
      <text class="task-card-title">当前任务仍在处理</text>
      <text class="task-card-text">{{generationTask.progressText || '处理中...'}}</text>
    </view>
    <view class="task-card-tag">LIVE</view>
  </view>

  <view class="task-card error" wx:if="{{generationTask && generationTask.status === 'error' && generationTask.error}}">
    <view class="task-card-icon error-mark">!</view>
    <view class="task-card-content">
      <text class="task-card-title">上一个生成任务失败</text>
      <text class="task-card-text">{{generationTask.error}}</text>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{assets.length === 0}}">
    <image class="empty-logo" src="/assets/logo-cube.svg" mode="aspectFit" />
    <text class="empty-title">你的模型库还是空的</text>
    <text class="empty-hint">生成完成后，模型会自动出现在这里，你可以继续预览、下载或管理历史记录。</text>
  </view>

  <!-- 列表 -->
  <view class="list" wx:else>
    <view class="asset-item" wx:for="{{assets}}" wx:key="id">
      <view class="asset-cover">
        <image wx:if="{{item.coverUrl}}" class="asset-cover-image" src="{{item.coverUrl}}" mode="aspectFill" />
        <view wx:else class="asset-cover-fallback">
          <image class="mark-cube-image" src="/assets/logo-cube.svg" mode="aspectFit" />
        </view>
      </view>
      <view class="asset-info">
        <text class="asset-name">{{item.name}}</text>
        <text class="asset-time">{{item.createdAt}}</text>
        <view class="asset-pills">
          <text class="asset-pill">GLB</text>
          <text class="asset-pill">3D Asset</text>
        </view>
      </view>
      <view class="asset-actions">
        <view class="action-btn" catchtap="previewGlb" data-url="{{item.glbUrl}}" data-name="{{item.name}}" data-id="{{item.id}}">预览</view>
        <view class="action-btn" catchtap="downloadGlb" data-url="{{item.glbUrl}}" data-name="{{item.name}}">下载</view>
        <view class="action-btn danger" catchtap="deleteAsset" data-id="{{item.id}}" data-name="{{item.name}}">删除</view>
      </view>
    </view>
  </view>

</view>
